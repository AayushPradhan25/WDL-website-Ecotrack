# Database Configuration
DATABASE_URL="postgresql://username:password@localhost:5432/ecosmart"

# JWT Configuration (REQUIRED - must be at least 32 characters)
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production-min-32-chars"

# CORS Configuration (comma-separated list of allowed origins)
ALLOWED_ORIGINS="http://localhost:3000,http://localhost:8080,http://127.0.0.1:8080"

# Seed Data Passwords (optional - defaults to admin123/user123 if not set)
SEED_ADMIN_PASSWORD="admin123"
SEED_USER_PASSWORD="user123"

# Server Configuration
PORT=3000
