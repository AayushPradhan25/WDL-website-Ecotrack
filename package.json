{
    "name": "ecosmart-root",
    "version": "1.0.0",
    "scripts": {
        "start": "npx concurrently \"npm run start:dev --prefix eco-smart-backend\" \"npx http-server ./ -p 8080\"",
        "backend": "npm run start:dev --prefix eco-smart-backend",
        "frontend": "npx http-server ./ -p 8080"
    },
    "devDependencies": {
        "concurrently": "^8.2.2",
        "http-server": "^14.1.1"
    },
    "dependencies": {
        "@nestjs/event-emitter": "^3.1.0",
        "@nestjs/platform-socket.io": "^11.1.21",
        "@nestjs/websockets": "^11.1.21",
        "socket.io": "^4.8.3"
    }
}
